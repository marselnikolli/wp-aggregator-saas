{
  "name": "wp-aggregator-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm --parallel -r build",
    "db:push": "pnpm --filter server exec prisma db push",
    "db:migrate": "pnpm --filter server exec prisma migrate dev",
    "db:generate": "pnpm --filter server exec prisma generate",
    "db:studio": "pnpm --filter server exec prisma studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  }
}
