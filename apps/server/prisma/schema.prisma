generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String?
  role        String   @default("admin")
  totpSecret  String?
  totpEnabled Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  apiKeys     ApiKey[]
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  keyHash   String    @unique
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  @@index([keyHash])
}

model Site {
  id              String        @id @default(cuid())
  name            String
  url             String
  apiUser         String
  apiPassword     String
  jwtToken        String?
  enabled         Boolean       @default(true)
  defaultCategory String?
  defaultAuthorId Int?
  lastPublished   DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishTasks    PublishTask[]
  socialAccounts  SocialAccount[]

  @@index([enabled])
}

model Source {
  id          String           @id @default(cuid())
  name        String
  endpoint    String
  type        SourceType       @default(RSS)
  enabled     Boolean          @default(true)
  interval    String?
  username    String?
  password    String?
  lastFetch   DateTime?
  fetchStatus FetchStatus      @default(NEVER)
  lastError   String?
  fetchCount  Int              @default(0)
  errorCount  Int              @default(0)
  fieldMap          Json?
  categoryMappings  Json?
  paginationParam   String?
  tags              String[]         @default([])
  minDelaySec       Int              @default(1)
  userAgent         String?
  proxyUrl          String?
  categoryMap       Json?
  sortOrder         Float            @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  posts       AggregatedPost[]
  fetchJobs   FetchJob[]

  @@index([enabled])
  @@index([lastFetch])
}

model AggregatedPost {
  id             String         @id @default(cuid())
  sourceId       String
  source         Source         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  remoteId       String?
  title          String
  content        String?        @db.Text
  excerpt        String?
  imageUrl       String?
  originalUrl    String?
  author         String?
  hash           String         @unique
  categories     String[]       @default([])
  aiTags         String[]       @default([])
  language       String         @default("en")
  aiSummary         String?        @db.Text
  aiTitle           String?
  qualityScore      Int?
  embedding         String?        @db.Text
  semanticDupOf     String?
  publishStatus  PublishStatus  @default(DRAFT)
  scheduledDate  DateTime?
  publishedDate  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  publishTasks   PublishTask[]
  socialPosts    SocialPost[]

  @@index([sourceId])
  @@index([publishStatus])
  @@index([createdAt])
  @@index([hash])
}

model PublishTask {
  id               String         @id @default(cuid())
  postId           String
  post             AggregatedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  siteId           String
  site             Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  status           TaskStatus     @default(PENDING)
  wpStatus         String         @default("publish")
  scheduledDate    DateTime?
  wpPostId         Int?
  wpUrl            String?
  categoryOverride String?
  tagOverrides     String[]       @default([])
  error            String?
  attempts         Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([postId, siteId])
  @@index([status])
}

model FetchJob {
  id        String      @id @default(cuid())
  sourceId  String
  source    Source      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  status    FetchStatus @default(PENDING)
  fetched   Int         @default(0)
  newPosts  Int         @default(0)
  error     String?
  duration  Int?
  createdAt DateTime    @default(now())

  @@index([sourceId])
  @@index([createdAt])
  @@index([sourceId, createdAt])
}

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

enum SourceType {
  RSS
  WP_API
  CUSTOM_API
}

enum FetchStatus {
  NEVER
  PENDING
  OK
  ERROR
}

enum PublishStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

enum TaskStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model Pipeline {
  id              String   @id @default(cuid())
  name            String
  enabled         Boolean  @default(true)
  // Source filter: null = all sources; otherwise JSON array of sourceIds or tag strings
  sourceFilter    Json?
  qualityMin      Int      @default(0)
  autoPublish     Boolean  @default(false)
  siteIds         String[] @default([])
  defaultStatus   String   @default("publish")
  // Cron expression, e.g. "0 8 * * *" = every day at 08:00
  schedule             String?
  categoryFilter       String[] @default([])
  translateTo          String?
  targetCategory       String?
  publishWindowHours   Int      @default(0)
  aiPrompt             String?
  sortOrder            Int      @default(0)
  socialAccountId      String?
  socialTemplate       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([enabled])
}

model WebhookLog {
  id           String   @id @default(cuid())
  url          String
  statusCode   Int?
  requestBody  String   @db.Text
  responseBody String?  @db.Text
  durationMs   Int?
  success      Boolean
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  userEmail    String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([resourceType, resourceId])
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
}

enum SocialStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  SCHEDULED
  CANCELLED
}

model SocialAccount {
  id                 String          @id @default(cuid())
  name               String
  platform           SocialPlatform
  pageId             String
  accessToken        String
  appId              String?
  appSecret          String?
  longLivedUserToken String?
  lastRotation       DateTime?
  rotationDays       Int             @default(50)
  linkedAccountId    String?
  linkedAccount      SocialAccount?  @relation("AccountLink", fields: [linkedAccountId], references: [id], onDelete: SetNull)
  linkedAccounts     SocialAccount[] @relation("AccountLink")
  siteId             String?
  site               Site?           @relation(fields: [siteId], references: [id], onDelete: SetNull)
  enabled            Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  socialPosts        SocialPost[]
}

model SocialPost {
  id             String         @id @default(cuid())
  postId         String
  post           AggregatedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  accountId      String
  account        SocialAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform       SocialPlatform
  template       String
  status         SocialStatus   @default(PENDING)
  scheduledAt    DateTime?
  publishedAt    DateTime?
  platformPostId String?
  error          String?
  reach          Int?
  impressions    Int?
  engagement     Int?
  createdAt      DateTime       @default(now())

  @@index([postId])
  @@index([accountId])
  @@index([status])
  @@index([createdAt])
}

model CaptionTemplate {
  id              String         @id @default(cuid())
  name            String
  platform        SocialPlatform
  language        String         @default("sq")
  includeHashtags Boolean        @default(true)
  includeExcerpt  Boolean        @default(false)
  brandingText    String?
  emojiStyle      String         @default("category")
  categoryColors  Json?
  createdAt       DateTime       @default(now())
}

model ImageTemplate {
  id        String         @id @default(cuid())
  name      String
  platform  SocialPlatform
  elements  Json           // TemplateElement[] (see below)
  logoUrl   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}
